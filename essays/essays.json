{
"nodes":[

{% assign essays = site.posts | where:"essay",true %}

{% for post in essays %}

{
"id":{{post.title | jsonify}},
"title":{{post.title | jsonify}},
"url":{{post.url | jsonify}},
"subtitle":{{post.subtitle | default:post.excerpt | strip_html | truncate:120 | jsonify}},
"cluster":{{post.cluster | default:"history" | jsonify}},
"tags":{{post.tags | jsonify}}
}

{% unless forloop.last %},{% endunless %}

{% endfor %}

]
}